# PostgreSQL connection (matches docker-compose.yml defaults)
SPINE_DB_URL=postgresql+asyncpg://spine:spine@localhost:5433/spine

# Required for initial admin setup — pick any secret string
SPINE_SETUP_KEY=your-secret-setup-key

# Optional: Tavily API key for web search in dossier generation
SPINE_TAVILY_API_KEY=

# Optional: JWT secret (auto-generated if not set)
# SPINE_JWT_SECRET=

# Optional: CORS origins (comma-separated)
# SPINE_CORS_ORIGINS=http://localhost:3000

# Optional: set True behind HTTPS
# SPINE_COOKIE_SECURE=true
